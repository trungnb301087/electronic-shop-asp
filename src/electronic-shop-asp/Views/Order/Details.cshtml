@model electronic_shop_asp.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container py-5">
    <h2 class="mb-4">Chi tiết đơn hàng - @Model.Id</h2>

    <div class="mb-4">
        <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
        <p><strong>Địa chỉ giao hàng:</strong> @Model.ShippingAddress</p>
        <p><strong>Số điện thoại:</strong> @Model.Phone</p>
        <p><strong>Trạng thái:</strong> @Model.Status</p>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered text-center align-middle">
            <thead class="table-light">
                <tr>
                    <th>Ảnh</th>
                    <th>Sản phẩm</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderDetails ?? new List<electronic_shop_asp.Models.OrderDetail>())
                {
                    <tr>
                        <td style="width:120px;">
                            <img src="~/img/@item.Product?.ImageUrl" class="img-fluid" style="max-height:80px;" />
                        </td>
                        <td>@item.Product?.Name</td>
                        <td>@item.UnitPrice.ToString("N0") đ</td>
                        <td>@item.Quantity</td>
                        <td>@((item.UnitPrice * item.Quantity).ToString("N0")) đ</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-end mt-3">
        <h4>Tổng cộng: <span class="text-primary">@Model.TotalAmount.ToString("N0") đ</span></h4>
    </div>
</div>