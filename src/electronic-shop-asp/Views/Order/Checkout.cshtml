@model electronic_shop_asp.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container py-5">
    <h2 class="mb-4">Thanh toán đơn hàng</h2>

    <div class="row">
        <div class="col-lg-7">
            <div class="border rounded p-4 shadow-sm">
                <h4 class="mb-3">Thông tin nhận hàng</h4>

                <form asp-action="Checkout" method="post">
                    <div class="mb-3">
                        <label asp-for="ShippingAddress" class="form-label">Địa chỉ giao hàng</label>
                        <input asp-for="ShippingAddress" class="form-control" />
                        <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-success">
                        Đặt hàng
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="border rounded p-4 shadow-sm">
                <h4 class="mb-3">Đơn hàng của bạn</h4>

                @if (Model.CartItems != null)
                {
                    @foreach (var item in Model.CartItems)
                    {
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <div>
                                <strong>@item.Product?.Name</strong><br />
                                <small>Số lượng: @item.Quantity</small>
                            </div>
                            <div>
                                @((item.Product?.Price * item.Quantity)?.ToString("N0")) đ
                            </div>
                        </div>
                    }
                }

                <div class="d-flex justify-content-between mt-3">
                    <h5>Tổng cộng:</h5>
                    <h5 class="text-primary">@Model.TotalAmount.ToString("N0") đ</h5>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}