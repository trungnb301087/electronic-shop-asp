@model electronic_shop_asp.Models.Wishlist

@{
    ViewData["Title"] = "Danh sách yêu thích";
    var items = Model?.WishlistItems?.ToList() ?? new List<electronic_shop_asp.Models.WishlistItem>();
}

<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6 wow fadeInUp" data-wow-delay="0.1s">
        Danh sách yêu thích
    </h1>
    <ol class="breadcrumb justify-content-center mb-0 wow fadeInUp" data-wow-delay="0.3s">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        </li>
        <li class="breadcrumb-item active text-white">Yêu thích</li>
    </ol>
</div>

<div class="container-fluid shop py-5">
    <div class="container py-5">

        <div class="mx-auto text-center mb-5" style="max-width: 700px;">
            <h4 class="text-primary mb-3">Sản phẩm bạn đã yêu thích</h4>
            <p class="text-muted">
                Lưu lại những sản phẩm bạn quan tâm để xem lại nhanh hơn.
            </p>
        </div>

        @if (!items.Any())
        {
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="border rounded p-5 text-center shadow-sm bg-light">
                        <i class="fas fa-heart text-danger mb-3" style="font-size: 50px;"></i>
                        <h3 class="mb-3">Danh sách yêu thích đang trống</h3>
                        <p class="text-muted mb-4">
                            Bạn chưa thêm sản phẩm nào vào danh sách yêu thích.
                        </p>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4 py-2">
                            Tiếp tục mua sắm
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="row g-4 product">
                @foreach (var item in items)
                {
                    <div class="col-md-6 col-lg-4 d-flex">
                        <div class="product-item rounded wow fadeInUp w-100" data-wow-delay="0.1s">

                            <div class="product-item-inner border rounded">

                                <div class="product-item-inner-item">
                                    <img src="~/img/@item.Product?.ImageUrl"
                                         class="img-fluid w-100 rounded-top"
                                         alt="@item.Product?.Name">

                                    <div class="product-details">
                                        <a asp-controller="Product"
                                           asp-action="Detail"
                                           asp-route-id="@item.ProductId">
                                            <i class="fa fa-eye fa-1x"></i>
                                        </a>

                                    </div>
                                </div>

                                <div class="text-center rounded-bottom p-4">
                                    <a class="d-block mb-2">
                                        @(item.Product?.Category?.Name ?? "Chưa phân loại")
                                    </a>

                                    <a asp-controller="Product"
                                       asp-action="Detail"
                                       asp-route-id="@item.ProductId"
                                       class="d-block h4">
                                        @item.Product?.Name
                                    </a>

                                    <span class="text-primary fs-5">
                                        @((item.Product?.Price ?? 0).ToString("N0"))đ
                                    </span>
                                </div>
                            </div>

                            <div class="product-item-add border border-top-0 rounded-bottom text-center p-4 pt-0">
                                <a asp-controller="Cart"
                                   asp-action="AddToCart"
                                   asp-route-productId="@item.ProductId"
                                   class="btn btn-primary border-secondary rounded-pill py-2 px-4 mb-3">
                                    <i class="fas fa-shopping-cart me-2"></i> Thêm vào giỏ hàng
                                </a>

                                <div>
                                    <a asp-controller="Wishlist"
                                       asp-action="Toggle"
                                       asp-route-productId="@item.ProductId"
                                       class="btn btn-outline-danger rounded-pill py-2 px-4">
                                        <i class="fas fa-trash-alt me-2"></i> Xóa khỏi yêu thích
                                    </a>
                                </div>
                            </div>

                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>