<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="~/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />
    <style>
        body {
            background-color: #f8f9fa;
        }

        .admin-sidebar {
            width: 260px;
            min-height: 100vh;
            background: #212529;
        }

            .admin-sidebar a {
                color: #fff;
                text-decoration: none;
                display: block;
                padding: 12px 16px;
                border-radius: 8px;
                margin-bottom: 8px;
            }

                .admin-sidebar a:hover {
                    background: #343a40;
                }

        .admin-content {
            flex: 1;
            padding: 24px;
        }

        .admin-brand {
            font-size: 24px;
            font-weight: bold;
            color: #ffc107;
        }
    </style>
</head>
<body>
    <div class="d-flex">
        <div class="admin-sidebar p-3">
            <div class="admin-brand mb-4">ADMIN PANEL</div>

            <a asp-area="Admin" asp-controller="Admin" asp-action="Index">
                <i class="fas fa-home me-2"></i> Dashboard
            </a>

            <a asp-area="Admin" asp-controller="Product" asp-action="Index">
                <i class="fas fa-box me-2"></i> Quản lý sản phẩm
            </a>

            <a asp-area="Admin" asp-controller="Category" asp-action="Index">
                <i class="fas fa-list me-2"></i> Quản lý danh mục
            </a>

            <a asp-area="Admin" asp-controller="Order" asp-action="Index">
                <i class="fas fa-shopping-bag me-2"></i> Quản lý đơn hàng
            </a>

            <a asp-area="Admin" asp-controller="User" asp-action="Index">
                <i class="fas fa-users me-2"></i> Quản lý người dùng
            </a>

            <hr class="text-white" />

            <a asp-controller="Home" asp-action="Index" asp-area="">
                <i class="fas fa-arrow-left me-2"></i> Về website
            </a>
        </div>

        <div class="admin-content">
            @RenderBody()
        </div>
    </div>

    <script src="~/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>